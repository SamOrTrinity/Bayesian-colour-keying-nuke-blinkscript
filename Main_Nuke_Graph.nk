 kernelSource "kernel InitMatte : ImageComputationKernel<ePixelWise>\n\{\n    Image<eRead, eAccessPoint, eEdgeClamped> D0;\n    Image<eWrite> matte;\n\n    param: float Et;\n    void define() \{ defineParam(Et, \"Et\",17.0f); \}\n\n    void process(int2 p)\n    \{\n        float4 d = D0();\n        float E = d.x;  // energy is the same in all channels, just read one\n\n        float val = (E > Et) ? 1.0f : 0.0f;\n        matte() = float4(val, val, val, 1.0f);\n    \}\n\};"
