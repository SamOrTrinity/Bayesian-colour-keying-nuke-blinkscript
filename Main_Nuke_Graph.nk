BlinkScript {
 inputs 3
 recompileCount 43
 ProgramGroup 1
 KernelDescription "3 \"DataCostYUV\" iterate pixelWise 7919a7c879967fc8b8bc1c093a726a3b09ffb1aca91a6ad7311777831b4d4f82 4 \"img\" Read Point \"mu\" Read Random \"var\" Read Random \"out\" Write Point 1 \"epsilon\" Float 1 vTeGNQ== 1 \"eps\" 1 1 Default 0"
 kernelSource "kernel DataCostYUV : ImageComputationKernel<ePixelWise>\n\{\n    Image<eRead, eAccessPoint,  eEdgeClamped> img;   // FULL FRAME colorspace output\n    Image<eRead, eAccessRandom, eEdgeClamped> mu;    // 1x1 mean — no reformat needed\n    Image<eRead, eAccessRandom, eEdgeClamped> var;   // 1x1 variance — no reformat needed\n    Image<eWrite> out;\n\n    param: float eps;\n    void define() \{ defineParam(eps, \"epsilon\",1e-6f); \}\n\n    void process(int2 p)\n    \{\n        float4 I = img();\n\n        // Read the single pixel from the 1x1 images\n        // Using their bounding box origin rather than hardcoded (0,0)\n        float4 M = mu(mu.bounds.x1, mu.bounds.y1);\n        float4 V = var(var.bounds.x1, var.bounds.y1);\n\n        float dy = I.x - M.x;\n        float du = I.y - M.y;\n        float dv = I.z - M.z;\n\n        float vy = max(V.x, eps);\n        float vu = max(V.y, eps);\n        float vv = max(V.z, eps);\n        \n        float wy = 0.1f; // or 0.05\n\n        float E = wy*(dy*dy)/(2.0f*vy) + (du*du)/(2.0f*vu) + (dv*dv)/(2.0f*vv);\n\n        out() = float4(E, E, E, 1.0f);\n    \}\n\};"
 rebuild ""
 DataCostYUV_epsilon 2e-05
 rebuild_finalise ""
 name BlinkScript18
 xpos -998
 ypos -231
}
