 kernelSource "kernel MRFStep : ImageComputationKernel<ePixelWise>\n\{\n    Image<eRead, eAccessPoint,  eEdgeClamped> D0;\n    Image<eRead, eAccessRandom, eEdgeClamped> m;\n    Image<eWrite> out;\n\n    param: float Et;\n    param: float lambda;\n\n    void define()\n    \{\n        defineParam(Et,     \"Et\",     17.0f);\n        defineParam(lambda, \"lambda\", 0.001f);\n    \}\n\n    void process(int2 p)\n\{\n    float Ebg = D0().x;\n\n    // Foreground bias (critical)\n    float Efg = Et-0.3f;\n\n    int fg = 0;\n    fg += (m(p.x - 1, p.y    ).x > 0.5f) ? 1 : 0;\n    fg += (m(p.x + 1, p.y    ).x > 0.5f) ? 1 : 0;\n    fg += (m(p.x,     p.y - 1).x > 0.5f) ? 1 : 0;\n    fg += (m(p.x,     p.y + 1).x > 0.5f) ? 1 : 0;\n    \n    fg += (m(p.x-1,     p.y - 1).x > 0.5f) ? 1 : 0;\n    fg += (m(p.x-1,     p.y + 1).x > 0.5f) ? 1 : 0;\n    fg += (m(p.x+1,     p.y - 1).x > 0.5f) ? 1 : 0;\n    fg += (m(p.x+1,     p.y + 1).x > 0.5f) ? 1 : 0;\n\n    float E0 = Ebg + lambda * float(fg);\n    float E1 = Efg + lambda * float(8 - fg);\n\n    float val = (E1 < E0) ? 1.0f : 0.0f;\n    out() = float4(val, val, val, 1.0f);\n\}\n\};"
 rebuild ""
