 KernelDescription "3 \"comp\" iterate pixelWise e5d16c9afa0d3335cc5fe12e9a9ffddebb057544cf493da1d3a50ed207e82727 4 \"FG\" Read Point \"BG\" Read Point \"A\" Read Point \"out\" Write Point 0 0 0"
 kernelSource "kernel comp : ImageComputationKernel<ePixelWise>\n\n\{\n\nImage<eRead, eAccessPoint, eEdgeClamped> FG;\n\nImage<eRead, eAccessPoint, eEdgeClamped> BG;\n\nImage<eRead, eAccessPoint, eEdgeClamped> A;\n\nImage<eWrite> out;\n\n\n\nvoid process(int2 p)\n\n\{\n\nfloat3 fg = FG().xyz; // Extract RGB from RGBA\n\nfloat3 bg = BG().xyz; // Extract RGB from RGBA\n\nfloat a = A().x; // Alpha channel\n\n\n\nfloat3 result = fg * a + (1.0f - a) * bg;\n\n\n\nout()= float4(result, 1.0f); // Use this if output is RGB\n\n\n\}\n\n\};"
